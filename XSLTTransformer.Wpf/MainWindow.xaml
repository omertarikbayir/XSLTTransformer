<Window x:Class="XSLTTransformer.Wpf.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="XSLT Transformer - XML Dönüştürücü" Height="600" Width="900">
    <Grid Margin="10">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>
        <StackPanel Orientation="Horizontal" Margin="0,0,0,8">
            <Button Content="EN" Click="SetEnglish" Width="40"/>
            <Button Content="TR" Click="SetTurkish" Width="40" Margin="4,0"/>
            <TextBlock x:Name="StatusText" Margin="16,4,0,0"/>
        </StackPanel>
        <Grid Grid.Row="1">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>
            <TextBox x:Name="XmlInput" AcceptsReturn="True" TextWrapping="Wrap" Margin="0,0,4,0"/>
            <TextBox x:Name="XsltInput" Grid.Column="1" AcceptsReturn="True" TextWrapping="Wrap"/>
        </Grid>
        <Button Grid.Row="2" Content="Dönüştür / Transform" Click="OnTransform" Margin="0,8"/>
        <TextBox Grid.Row="3" x:Name="ResultOutput" AcceptsReturn="True" IsReadOnly="True" TextWrapping="Wrap"/>
        <TextBlock Grid.Row="4" x:Name="Footer" Text="GIB e-belge | XSLT 2/3"/>
    </Grid>
</Window>
